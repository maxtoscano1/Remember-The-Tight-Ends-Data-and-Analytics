function buildControls(tabKey){
  const t=TABS[tabKey];
  let opts='';
  for(const [k,v] of Object.entries(t.cats)) opts+=`<option value="${k}"${state.cat===k?' selected':''}>${v}</option>`;
  return `<div class="controls">
    <span class="control-label">Rank by</span>
    <select id="catSel">${opts}</select>
    <span class="note">${t.note}</span>
  </div>`;
}

function sortRows(rows,key,dir){
  return rows.slice().sort((a,b)=>{
    let av=a[key], bv=b[key];
    if(av===undefined||av===null)av=-Infinity; if(bv===undefined||bv===null)bv=-Infinity;
    return (av-bv)*dir;
  });
}

function renderFramework(){
  const t=TABS.framework;
  if(!state.cat) state.cat='TotComp';
  const rows=names.map(n=>({name:n,...DATA[n]}));
  const sorted=sortRows(rows,state.sortKey,state.sortDir);
  let h=buildControls('framework');
  h+='<table><thead><tr><th class="lft">#</th><th class="lft">Player</th>';
  t.cols.forEach(c=>{h+=`<th data-sk="${c.k}" class="${state.sortKey===c.k?'sorted'+(state.sortDir>0?' asc':''):''}">${c.l}</th>`;});
  h+='</tr></thead><tbody>';
  sorted.forEach((p,i)=>{
    h+=`<tr class="r${i+1}"><td class="rank">${i+1}</td><td class="name">${p.name}${teamBadge(p.name)}</td>`;
    t.cols.forEach(c=>{
      const cls=c.k===state.sortKey?'val-hi':'';
      h+=`<td class="${cls}">${num(p[c.k])}</td>`;
    });
    h+='</tr>';
  });
  h+='</tbody></table>';
  h+=`<div class="foot">Total Composite Value combines a player\u2019s blocking and receiving into one figure, weighted by difficulty and built to reward genuine two-way value while crediting elite receiving specialists. See &ldquo;Explaining The Framework&rdquo; for how to read each column. A WR Test Score of 5.50 or higher clears the bar to earn a WR Test Bonus.</div>`;
  return h;
}

