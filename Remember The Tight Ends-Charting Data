<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RTTE Leaderboard</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Archivo:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap');
:root{
  --bg:#0d0d0d; --panel:#161616; --panel2:#1a1a1a; --line:#2e2e2e;
  --ink:#f5f5f5; --dim:#8a8a8a; --accent:#f0883e; --accent2:#d4d4d4;
  --gold:#e3b341; --blue:#a0a0a0; --red:#f85149;
}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--ink);font-family:'Archivo',sans-serif;
  background-image:radial-gradient(circle at 50% 0%,rgba(240,136,62,.05),transparent 45%);
  min-height:100vh}
.wrap{max-width:1540px;margin:0 auto;padding:0 24px 80px}
header{margin:0 -24px 8px;padding:0}
.logobar{background:#0a0a0a;border-bottom:3px solid #fff;padding:18px 24px 16px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;gap:24px;overflow:hidden}.logobar .txt{flex:1;min-width:0}.logobar .player{height:122px;width:auto;flex-shrink:0;display:block}
.eyebrow{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:3px;color:var(--dim);text-transform:uppercase;margin-bottom:8px}
h1{font-family:'Oswald',sans-serif;font-weight:700;font-size:clamp(34px,6vw,68px);letter-spacing:1px;line-height:.92;text-transform:uppercase;color:#fff}
h1 span{color:#fff}
.sub{color:var(--dim);font-size:13px;margin-top:10px;font-family:'JetBrains Mono',monospace;padding:0 24px}
.tabs{display:flex;gap:2px;margin:28px 0 0;flex-wrap:wrap}
.tab{background:var(--panel);border:1px solid var(--line);border-bottom:none;padding:13px 22px;
  font-family:'Oswald',sans-serif;font-weight:600;font-size:14px;letter-spacing:.5px;text-transform:uppercase;
  color:var(--dim);cursor:pointer;transition:.15s;border-radius:8px 8px 0 0}
.tab:hover{color:var(--ink);background:var(--panel2)}
.tab.active{color:var(--accent);background:var(--panel2);border-color:var(--accent)}
.panel{background:var(--panel2);border:1px solid var(--line);border-radius:0 8px 8px 8px;padding:24px;min-height:400px;overflow-x:auto}
.controls{display:flex;gap:16px;align-items:center;margin-bottom:20px;flex-wrap:wrap}
.control-label{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:1px}
select{background:var(--panel);color:var(--ink);border:1px solid var(--line);border-radius:6px;padding:9px 14px;
  font-family:'Archivo',sans-serif;font-size:14px;font-weight:600;cursor:pointer;outline:none}
select:focus{border-color:var(--accent)}
.note{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--gold);margin-left:auto;opacity:.8}
table{min-width:100%;width:max-content;border-collapse:collapse;font-size:14px}
th{font-family:'Oswald',sans-serif;font-weight:600;text-transform:uppercase;letter-spacing:.5px;font-size:12px;
  color:var(--dim);text-align:right;padding:11px 12px;border-bottom:2px solid var(--line);cursor:pointer;user-select:none;white-space:nowrap}
th:first-child,th.lft{text-align:left}
th:hover{color:var(--accent)}
th.sorted{color:var(--accent)}
th.sorted::after{content:" \25BC";font-size:8px}
th.sorted.asc::after{content:" \25B2"}
td{padding:11px 12px;text-align:right;border-bottom:1px solid var(--line);font-variant-numeric:tabular-nums;font-family:'JetBrains Mono',monospace}
td.name{text-align:left;font-family:'Archivo',sans-serif;font-weight:600;font-size:15px;white-space:nowrap}
td.rank{color:var(--dim);font-weight:700;width:40px}
tr:hover td{background:rgba(240,136,62,.05)}
.r1 .rank{color:var(--accent)}.r2 .rank{color:#c9c9c9}.r3 .rank{color:#9a9a9a}
.val-hi{color:var(--accent2);font-weight:600}
.val-lo{color:var(--dim)}
.bar{display:inline-block;height:6px;background:var(--accent);border-radius:3px;vertical-align:middle;margin-left:8px;opacity:.5}
.team{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;letter-spacing:.5px;padding:2px 7px;border-radius:4px;margin-left:9px;vertical-align:middle;transform:translateY(-1px)}

.pct{font-size:11px;color:var(--dim);margin-left:4px}
.zero{color:var(--red);opacity:.6}
.foot{margin-top:18px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);line-height:1.7}
.subhead{font-family:'Oswald';font-weight:600;text-transform:uppercase;letter-spacing:1px;font-size:13px;color:var(--accent);margin:22px 0 10px;padding-top:4px}
.explain-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px}
.ex-card{background:var(--panel);border:1px solid var(--line);border-left:3px solid var(--accent);border-radius:6px;padding:16px 18px}
.ex-card.alt{border-left-color:var(--dim)}
.ex-t{font-family:'Oswald',sans-serif;font-weight:600;font-size:16px;letter-spacing:.3px;color:var(--ink);margin-bottom:7px}
.ex-d{font-size:13.5px;line-height:1.55;color:var(--dim)}
.grouprow th.grp{text-align:center;font-family:'Oswald',sans-serif;font-weight:600;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--accent);padding:6px 12px 8px;border-bottom:none;vertical-align:bottom}
.grouprow th{border-bottom:none}

.dp-name{font-family:'Oswald';font-weight:600;font-size:14px;letter-spacing:.5px;color:#e8e8e8;margin:18px 0 7px;display:flex;align-items:center;gap:8px}
.dp-tbl{max-width:660px}

.plink{cursor:pointer;border-bottom:1px dotted rgba(240,136,62,.55)}
.plink:hover{color:var(--accent)}
.cardmenu{display:flex;gap:8px;flex-wrap:wrap;margin:4px 0 14px}
.cardbtn{padding:7px 16px;border:1px solid #333;border-radius:6px;cursor:pointer;font-family:'Oswald',sans-serif;
  letter-spacing:.5px;font-size:13px;color:#aaa;background:#161616;text-transform:uppercase}
.cardbtn:hover{color:#eee;border-color:#555}
.cardbtn.active{color:var(--accent);border-color:var(--accent)}

#cardOverlay{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:99;overflow:auto;padding:34px 12px;display:flex;align-items:flex-start;justify-content:center}
.cardclose{position:fixed;top:14px;right:22px;font-size:26px;color:#ddd;cursor:pointer;z-index:101;font-family:'Oswald',sans-serif;background:#1c1c1c;border:1px solid #444;border-radius:6px;padding:2px 14px;line-height:1.4}
.cardclose:hover{color:var(--accent);border-color:var(--accent)}
</style>
</head>
