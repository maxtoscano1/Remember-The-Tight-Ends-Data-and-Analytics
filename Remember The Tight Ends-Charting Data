<div class="wrap">
<header>
  <div class="logobar">
    <div class="txt">
      <div class="eyebrow">2025 Charting &bull; Proprietary Framework</div>
      <h1>Remember The Tight Ends</h1>
    </div>
    <img class="player" src="data:image/png;base64," alt="RTTE #87">
  </div>
  <div class="sub">TE Value Leaderboard &bull; Data on 8 game samples &bull; sortable by category &bull; click any column to rank</div>
</header>

<div class="tabs" id="tabs">
  <div class="tab active" data-tab="framework">RTTE Framework Scores</div>
