function renderRouteTree(){
  const CELLS=[['overall','Overall'],['ym','Y/Att v Man'],['yz','Y/Att v Zone'],['sm','Slot v Man'],['sz','Slot v Zone'],['om','Outside v Man'],['oz','Outside v Zone']];
  const get=(rt,key)=>{
    if(!rt) return null;
    if(key==='overall') return rt.overall;
    const m={ym:['Y/Attached','Man'],yz:['Y/Attached','Zone'],sm:['Slot','Man'],sz:['Slot','Zone'],om:['Outside','Man'],oz:['Outside','Zone']}[key];
    return rt[m[0]][m[1]];
  };
  const fmt=(c)=>(c&&c.att>0)?`${c.win}/${c.att} \u00b7 ${Math.round(c.win/c.att*100)}%`:'\u2013';
  const players=Object.keys(DATA).filter(n=>DATA[n].routetree);
  // route list = union, sorted by combined volume
  const vol={};
  players.forEach(n=>{const rt=DATA[n].routetree;Object.keys(rt).forEach(r=>{vol[r]=(vol[r]||0)+rt[r].overall.att;});});
  const routes=Object.keys(vol).sort((a,b)=>vol[b]-vol[a]);
  const route=(state.route&&routes.includes(state.route))?state.route:routes[0];
  const sk=CELLS.some(c=>c[0]===state.sortKey)?state.sortKey:'overall';
  // selector
  let h=`<div class="controls"><span class="control-label">Route</span><select id="catSel">`;
  routes.forEach(r=>{h+=`<option value="${r}" ${r===route?'selected':''}>${r}</option>`;});
  h+=`</select><span class="note">${TABS.routetree.note}</span></div>`;
  // leaderboard for the selected route
  h+=`<div class="subhead">${route} \u2014 Leaderboard</div>`;
  h+=`<div class="tblwrap"><table><thead><tr><th>#</th><th class="lft">Player</th>`;
  CELLS.forEach(([k,l])=>{h+=`<th data-sk="${k}" class="${sk===k?'sorted'+(state.sortDir>0?' asc':''):''}">${l}</th>`;});
  h+=`</tr></thead><tbody>`;
  const rows=players.map(n=>{
    const rt=DATA[n].routetree[route];
    const c=get(rt,sk);
    const pct=(c&&c.att>0)?c.win/c.att:null;
    return {n, rt, pct, att:c?c.att:0, win:c?c.win:0};
  });
  const ranked=rows.filter(r=>r.pct!==null).sort((a,b)=>((b.pct-a.pct)||(b.att-a.att)||(b.win-a.win))*(state.sortDir>0?-1:1));
  const unranked=rows.filter(r=>r.pct===null);
  let lastPct=null,lastRank=0;
  ranked.forEach((r,i)=>{
    const rank=(r.pct===lastPct)?lastRank:i+1; lastPct=r.pct; lastRank=rank;
    h+=`<tr class="r${rank}"><td>${rank}</td><td class="name">${r.n}${teamBadge(r.n)}</td>`;
    CELLS.forEach(([k])=>{h+=`<td>${fmt(get(r.rt,k))}</td>`;});
    h+=`</tr>`;
  });
  unranked.forEach(r=>{
    h+=`<tr><td>\u2013</td><td class="name">${r.n}${teamBadge(r.n)}</td>`;
    CELLS.forEach(([k])=>{h+=`<td>${fmt(get(r.rt,k))}</td>`;});
    h+=`</tr>`;
  });
  h+=`</tbody></table></div>`;
  h+=`<div class="foot">Click any column to rank players on that route \u00d7 alignment \u00d7 coverage cell. W/A = process wins / route attempts. Overall counts every charted rep of the route; alignment \u00d7 coverage cells require both tags \u2014 checkdowns and screens are often uncharted for coverage, so crosstab cells can sum below Overall. Route trees populate per player as charting completes \u2014 currently charted: ${players.join(', ')}.</div>`;
  return h;
}

function renderExplained(){
  /* ===== EXPLAINING THE FRAMEWORK — score explainer copy (text-editable) ===== */
  const items=[
    ["Blocking Exposure","How often a player is deployed in the hardest in-line blocking situations. Playside and covered assignments, a solo block on a DL that the OC is comfortable running behind, separates real blockers from those who need to be hidden, which creates subsequent limitations. It captures trust and schematic participation in the run game, independent of how well he actually executes. Harder situations are weighted more heavily as they are more important."],
    ["Total Blocking","This measures exposure in combination with performance. Tougher assignments count for more, so winning hard blocks moves the number more than winning easy ones. The highest performers will execute at a high level while being leaned on at a high level. This captures the total schematic value-add of a TE to their unit’s run game."],
    ["Receiving Exposure","How often a player is split into true receiving alignments, in a true slot and out-wide, where a tight end is matched against corners and nickels rather than linebackers and safeties. It isolates WR-caliber deployment. Attached/in-line/Y targets are excluded here on purpose. This exposure delineates schematic participation in the extremes and in the highest value schematic roles of the PASSING game."],
    ["Total Receiving","The full receiving picture: how a player is used across every alignment and coverage type, combined with how often he wins, with additional credit for yards-after-catch and contested catch wins. Harder alignment/coverage combinations are weighted more heavily. Similar to total blocking and the run game, this measures a TE’s impact on the passing chessboard"],
    ["WR Test Score","How a player performs specifically in wide-receiver alignments against man and zone coverage. A high grade means he separates and wins like a real WR, not just a tight end benefiting from TE coverage realities and matchups that are much easier than true perimeter responsibilities."],
    ["Composite Exposure","A single measure of how complete a player’s deployment is across the spectrum of an offense’s needs in the run and pass game. While this rewards balance, a player who truly adds substantial value in an extreme manner will see that value reflected."],
    ["Base Composite","The core, complete valuation of a TE: blocking and receiving combined into one number, with receiving carrying a bit more weight (weighted 65% to 35% in favor of receiving) to reflect the relative value of the contributions. This is built so that a full-time level of credibility at only one job can’t mask an absence at the other without positional transcendence, which is accounted for in the final composite."],
    ["WR Test Bonus","Extra credit for the elite of the elite receivers. When a player’s WR Test Score clears a high bar, he earns additional value. If he clears this bar, it means he can functionally replace a third WR and play a full-time role, even if he can’t fill the TE fundamentals of in-line blocking. This is designed to accurately capture the unique value of players like Brock Bowers, Travis Kelce, or Tony Gonzalez. Even if a player receiving a bonus is indeed credible in-line, their ability to moonlight as a WR is a major boost to their baseline value. It’s a transcendence bump, and a necessary one."],
    ["Synthetic Blocking:  An In-Line Waiver","A fallback measure that applies in one specific situation only: when a player (1) clears the elite WR Test Score bar AND (2) has effectively no in-line blocking sample to grade. If he can’t block in-line, it means he can’t add TE value as a blocker. That means schematically,  his receiving is fake relative to alternatives.  If he clears the WR test, it means he can be paired with an in-line guy WITHOUT the unit losing anything by removing a third WR. As such, his secondary blocking contribution (move and other sheltered blocks) becomes schematically “real” and goes live as value relative to baseline. This prevents the composite from zeroing out if he does create that real, positionally transcendent receiving value. It rarely triggers; most players, even those not actually viable in-line,  have enough blocking volume to be measured directly."],
    ["Total Composite Value","The headline number. This is a complete figure that measures the impacts of run game and pass game contributions, not just in combination, but in their interaction with one another.  It rewards genuine two-way completeness while still crediting elite specialists, so different paths to value are captured fairly. The idea is to measure the total schematic chessboard impact. Elite in-line blockers can make their passing games better by creating conflict, elite flex receivers who can block in-line give you the ability to live in different worlds. How much does an individual player spread the defense thin and contribute to everything around them? That is the essence of the Tight End position. Now it has a statistic."],
  ];
  /* ===== DESIGN PRINCIPLES copy (text-editable) ===== */
  const principles=[
    ["Built on real math, not opinion","Every score is a defined quantitative measure built from charted play-by-play inputs. These are alignment, coverage, personnel grouping/the defense’s response, routes, and block types.  The framework combines these systematically rather than relying on gut feel. While this can be qualitatively determined by evaluators, the principal has never been mathematically quantified and stacked. The exact weightings and construction are proprietary, but the inputs are concrete, and the outputs are reproducible."],
    ["Two lenses: usage vs. performance","EXPOSURE scores isolate only the hardest reps to measure deployment. This is done to tell us who is trusted in the toughest spots. TOTAL scores fold that in with every usage and their total performance along that. Seeing both side by side, and the gap between them, is itself diagnostic. A player may be heavily used, but this tells us whether or not he SHOULD be, and when heavy usage may recede under better conditions."],
    ["Completeness is required, not averaged","The framework combines blocking and receiving in a way that won’t let strength in one area paper over absence in the other. A player who does only one job is measured as exactly that — the math doesn’t average the weakness away."],
    ["Why a player can score zero","A pure receiver who never blocks in-line, the fundamental distinction between TE and WR, can score zero on the composite. Not because he’s a bad player, but because he isn’t doing the tight end job while not transcending it as a receiver either. How a player is used tells that story. If a guy can only consistently win as a Y but can’t block like one, his schematic value in neutral situations is zero. You’re better off with a real Y at TE and a third WR who can just get in the way as a blocker."],
    ["Difficulty is weighted","Not all reps are equal. Winning against a corner out-wide or holding up on a DE on the playside of a run counts for more than easier assignments. The framework reflects that the hard reps are where value is actually created. That’s where the real ones separate themselves."],
  ];
  let h='<div class="controls"><span class="note" style="margin-left:0">How to read the leaderboard</span></div>';
  h+='<div class="subhead">The Scores</div>';
  h+='<div class="explain-grid">';
  items.forEach(([t,d])=>{ h+=`<div class="ex-card"><div class="ex-t">${t}</div><div class="ex-d">${d}</div></div>`; });
  h+='</div>';
  h+='<div class="subhead">Design Principles</div>';
  h+='<div class="explain-grid">';
  principles.forEach(([t,d])=>{ h+=`<div class="ex-card alt"><div class="ex-t">${t}</div><div class="ex-d">${d}</div></div>`; });
  h+='</div>';
  h+=`<div class="foot">W/A = Wins/Attempts. PS=Playside, BS=Backside, Cov=Covered, Unc=Uncovered.<br>
  A &ldquo;win&rdquo; is a process judgment \u2014 elements in the player\u2019s control executed at a high level \u2014 not simply the play\u2019s outcome.</div>`;
  return h;
}

function render(){
  const panel=document.getElementById('panel');
  let h='';
  if(state.tab==='framework') h=renderFramework();
  else if(state.tab==='receiving') h=renderReceiving();
  else if(state.tab==='blocking') h=renderBlocking();
  else if(state.tab==='personnel') h=renderPersonnel();
  else if(state.tab==='cards') h=renderCards();
  else if(state.tab==='routetree') h=renderRouteTree();
  else if(state.tab==='explained') h=renderExplained();
  else if(state.tab==='glossary') h=renderGlossary();
  panel.innerHTML=h;
  if(state.tab==='cards'){document.querySelectorAll('.cardbtn').forEach(b=>b.addEventListener('click',()=>openCard(b.dataset.player)));}
  decorateNames();
  // wire controls
  const sel=document.getElementById('catSel');
  if(sel) sel.addEventListener('change',e=>{
    state.cat=e.target.value;
    if(state.tab==='routetree') state.route=e.target.value;
    if(state.tab==='framework') state.sortKey=e.target.value;
    render();
  });
  // wire sortable headers (framework)
  panel.querySelectorAll('th[data-sk]').forEach(th=>{
    th.addEventListener('click',()=>{
      const k=th.dataset.sk;
      if(state.sortKey===k) state.sortDir*=-1; else {state.sortKey=k;state.sortDir=-1;}
      state.cat=k; render();
    });
  });
}

document.getElementById('tabs').addEventListener('click',e=>{
  if(!e.target.classList.contains('tab'))return;
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  e.target.classList.add('active');
  state.tab=e.target.dataset.tab;
  state.cat=null;
  if(state.tab==='framework'){state.sortKey='TotComp';state.sortDir=-1;}
  render();
});

render();
