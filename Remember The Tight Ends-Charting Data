  const nrows=names.map(n=>{
    const dp=DATA[n].def_pers; const o={name:n,has:!!dp};
    let tn=0,ts=0;
    ng.forEach(g=>{
      if(dp&&dp[g]&&dp[g].snaps>0&&dp[g].nickel!==undefined){o['nkl_'+g]=dp[g].nickel;tn+=dp[g].nickel*dp[g].snaps;ts+=dp[g].snaps;}
      else o['nkl_'+g]=null;
    });
    o.nkl_ov = ts>0 ? tn/ts : null;
    return o;
  });
  const nkey = (state.sortKey && /^nkl_/.test(state.sortKey)) ? state.sortKey : 'nkl_ov';
  nrows.sort((a,b)=>{const av=a[nkey],bv=b[nkey]; if(av==null&&bv==null)return 0; if(av==null)return 1; if(bv==null)return -1; return bv-av;});
  const nsel=(k)=> state.sortKey===k?' class="sorted"':'';
  h+='<table><thead><tr><th class="lft">#</th><th class="lft">Player</th>'+
     `<th data-sk="nkl_ov"${nsel('nkl_ov')}>Overall</th><th data-sk="nkl_11"${nsel('nkl_11')}>11 Pers</th>`+
     `<th data-sk="nkl_12"${nsel('nkl_12')}>12 Pers</th><th data-sk="nkl_13"${nsel('nkl_13')}>13 Pers</th>`+
     `<th data-sk="nkl_21"${nsel('nkl_21')}>21 Pers</th></tr></thead><tbody>`;
  nrows.forEach((r,i)=>{
    const c=(k)=> r[k]!=null ? (r[k]*100).toFixed(1)+'%' : '<span class="zero">\u2014</span>';
    const hl=(k)=> nkey===k?' class="val-hi"':'';
    h+=`<tr class="r${i+1}"><td class="rank">${r.has?i+1:''}</td><td class="name">${r.name}${teamBadge(r.name)}</td>`+
       `<td${hl('nkl_ov')}>${c('nkl_ov')}</td><td${hl('nkl_11')}>${c('nkl_11')}</td><td${hl('nkl_12')}>${c('nkl_12')}</td><td${hl('nkl_13')}>${c('nkl_13')}</td><td${hl('nkl_21')}>${c('nkl_21')}</td></tr>`;
  });
  h+='</tbody></table>';
  h+='<div class="foot">Share of each grouping\u2019s charted snaps that faced nickel personnel; Overall is snap-weighted across groupings. Click a grouping to rank by it. Populates per player as defensive personnel is charted.</div>';

  h+='<div class="subhead">Run / Pass Splits by Personnel</div>';
  h+='<table><thead><tr><th class="lft">Player</th><th>11 R/P</th><th>12 R/P</th><th>13 R/P</th><th>21 R/P</th><th>Pass%</th></tr></thead><tbody>';
  names.forEach(n=>{
    const rp=DATA[n].runpass;
    let tp=0,tr=0; Object.values(rp).forEach(x=>{tp+=x.pass;tr+=x.run;});
    const e=(tp+tr)===0;
    h+=`<tr><td class="name">${n}${teamBadge(n)}</td>`+
       ['11','12','13','21'].map(k=>`<td class="${e?'zero':''}">${rp[k].run}/${rp[k].pass}</td>`).join('')+
       `<td class="${e?'zero':'val-hi'}">${(tp+tr)>0?(tp/(tp+tr)*100).toFixed(0)+'%':'<span class=zero>\u2014</span>'}</td></tr>`;
  });
  h+='</tbody></table>';
  h+=`<div class="foot">R/P = Run snaps / Pass snaps in that personnel grouping.<br>
  Personnel &amp; run/pass populate once you chart personnel and the snap ledger.</div>`;
  return h;
}




const CARD_W=1120;
function openCard(n){
  if(!CARDS[n]) return;
  const old=document.getElementById('cardOverlay'); if(old) old.remove();
  const ov=document.createElement('div'); ov.id='cardOverlay';
  const x=document.createElement('div'); x.className='cardclose'; x.textContent='\u2715';
  const wrap=document.createElement('div'); wrap.style.cssText='position:relative;transform-origin:top left';
  const f=document.createElement('iframe');
  f.style.cssText='width:'+CARD_W+'px;height:1200px;border:0;border-radius:10px;background:#0a0a0a;display:block';
  f.setAttribute('scrolling','no');
  const html=new TextDecoder().decode(Uint8Array.from(atob(CARDS[n]), c=>c.charCodeAt(0)));
  const s=Math.min(1,(window.innerWidth-44)/CARD_W);
  wrap.style.transform='scale('+s+')';
  wrap.style.width=(CARD_W*s)+'px';
  f.addEventListener('load',()=>{try{
    const fit=()=>{const h=f.contentDocument.documentElement.scrollHeight+8; f.style.height=h+'px'; wrap.style.height=(h*s)+'px';};
    fit(); setTimeout(fit,300); setTimeout(fit,1200);
    new ResizeObserver(fit).observe(f.contentDocument.body);
  }catch(e){f.style.height='2200px';}});
  f.srcdoc=html;
  wrap.appendChild(f); ov.appendChild(wrap); document.body.appendChild(ov); document.body.appendChild(x);
  const close=()=>{ov.remove();x.remove();document.removeEventListener('keydown',esc);};
  const esc=(e)=>{if(e.key==='Escape')close();};
  ov.addEventListener('click',e=>{if(e.target===ov)close();});
  x.addEventListener('click',close);
  document.addEventListener('keydown',esc);
}
function goToCard(n){openCard(n);}
function decorateNames(){
  document.querySelectorAll('td.name').forEach(td=>{
    const node=td.childNodes[0];
    if(!node||node.nodeType!==3) return;
    const nm=node.textContent.trim();
    if(!CARDS[nm]) return;
    const a=document.createElement('span'); a.className='plink'; a.textContent=nm;
    a.addEventListener('click',()=>goToCard(nm));
    td.replaceChild(a,node);
  });
}


